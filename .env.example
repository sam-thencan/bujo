# libSQL / Turso connection. For local dev, point at a file.
# Local:
DATABASE_URL="file:./dev.db"
# Production (Turso):
# DATABASE_URL="libsql://your-db.turso.io"
# DATABASE_AUTH_TOKEN="your-turso-token"

# 32+ char random string used to sign session JWTs.
AUTH_SECRET="change-me-to-a-long-random-string-min-32-chars"

# Set to "closed" to disable public sign-ups after you've created your accounts.
SIGNUPS="open"

# Google OAuth. Create OAuth 2.0 credentials in Google Cloud Console and
# register http://localhost:3000/api/auth/google/callback (+ your production
# equivalent) as authorized redirect URIs. Leave blank to disable Google sign-in.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
